{
  "schemaVersion": 1,
  "suites": [
    {
      "id": "crypto.cid-json-values",
      "path": "crypto/cid-json-values.json",
      "assertions": ["cid.json"]
    },
    {
      "id": "crypto.cid-dag-pb-values",
      "path": "crypto/cid-dag-pb-values.json",
      "assertions": ["cid.dagpb.bytes", "cid.dagpb.stream"]
    },
    {
      "id": "crypto.jws-general",
      "path": "crypto/jws-general.json",
      "assertions": ["jws.general.sign", "jws.general.verify", "jws.general.payload"]
    },
    {
      "id": "crypto.jwe-encryption",
      "path": "crypto/jwe-encryption.json",
      "assertions": ["jwe.protected", "jwe.aead", "jwe.keywrap", "jwe.decrypt"]
    },
    {
      "id": "dwn.messages.basic-interface-messages",
      "path": "dwn/messages/basic-interface-messages.json",
      "assertions": ["cid.message", "cid.descriptor", "descriptor.roundtrip"]
    },
    {
      "id": "dwn.messages.sync-descriptors",
      "path": "dwn/messages/sync-descriptors.json",
      "assertions": ["cid.message", "cid.descriptor", "descriptor.roundtrip"]
    },
    {
      "id": "dwn.messages.sync-replies",
      "path": "dwn/messages/sync-replies.json",
      "assertions": ["messages-sync.replies"]
    },
    {
      "id": "dwn.protocols.configure-definitions",
      "path": "dwn/protocols/configure-definitions.json",
      "assertions": ["cid.message", "cid.descriptor", "descriptor.roundtrip"]
    },
    {
      "id": "dwn.protocols.permissions-records",
      "path": "dwn/protocols/permissions-protocol-records.json",
      "assertions": [
        "cid.message",
        "cid.descriptor",
        "cid.dagpb.bytes",
        "cid.dagpb.stream",
        "descriptor.roundtrip"
      ]
    },
    {
      "id": "dwn.state-index.operations",
      "path": "dwn/state-index/operations.json",
      "assertions": ["state-index.operations"]
    }
  ]
}
