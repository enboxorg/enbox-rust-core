{
  "$id": "https://identity.foundation/dwn/json-schemas/protocol-definition.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "published",
    "types",
    "structure"
  ],
  "properties": {
    "protocol": {
      "type": "string"
    },
    "published": {
      "type": "boolean"
    },
    "uses": {
      "$comment": "Maps alias names to external protocol URIs for composition. Each alias can be used in $ref values and cross-protocol role/of references using 'alias:path' syntax.",
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_-]*$": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "types": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "schema": {
              "type": "string"
            },
            "dataFormats": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "encryptionRequired": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "structure": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "$ref": "https://identity.foundation/dwn/json-schemas/protocol-rule-set.json"
        }
      }
    }
  }
}