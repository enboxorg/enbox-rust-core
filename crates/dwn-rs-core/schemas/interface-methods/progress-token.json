{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://identity.foundation/dwn/json-schemas/progress-token.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "streamId",
    "epoch",
    "position",
    "messageCid"
  ],
  "properties": {
    "streamId": {
      "type": "string",
      "minLength": 1
    },
    "epoch": {
      "type": "string",
      "minLength": 1
    },
    "position": {
      "type": "string",
      "minLength": 1
    },
    "messageCid": {
      "type": "string",
      "minLength": 1
    }
  }
}
